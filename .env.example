# Copier ce fichier en .env :  cp .env.example .env
# Variables lues par docker-compose ET par le backend.

# --- PostgreSQL (docker-compose) ---
POSTGRES_USER=clock
POSTGRES_PASSWORD=clock
POSTGRES_DB=ts_clock_app
# Port hôte exposé. 5433 par défaut pour ne pas entrer en conflit avec
# un PostgreSQL déjà installé localement (souvent sur 5432).
POSTGRES_PORT=5433

# --- Connexion utilisée par le backend (Bun.SQL) ---
DATABASE_URL=postgres://clock:clock@localhost:5433/ts_clock_app
